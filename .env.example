# ============================================
# Python Learning Tool - Environment Variables
# ============================================
# Copy this file to .env and fill in the values.

# Flask configuration: development | production | testing
FLASK_CONFIG=development

# Required in production - generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Database URL (required in production, defaults to SQLite in development)
# PostgreSQL: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://pluser:changeme@localhost:5432/pythonlearning

# Redis URL for rate limiting storage (optional, defaults to in-memory)
REDIS_URL=redis://localhost:6379/0

# Code sandbox mode: subprocess (default) or docker
SANDBOX_MODE=subprocess

# Docker sandbox settings (only used when SANDBOX_MODE=docker)
SANDBOX_IMAGE=pythonlearning-sandbox:latest
SANDBOX_TIMEOUT=10
SANDBOX_MEMORY_LIMIT=256m

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
